# Supabase Configuration
# Copy these values from your toc-crm/.env.local file
# These should be the SAME credentials as toc-crm (shared database)

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Supabase Anonymous Key (Public - safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (REQUIRED for AutoSEO webhook - write access)
# WARNING: Keep this secret! Never expose in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Site URL (used for generating blog post URLs in webhook responses)
NEXT_PUBLIC_SITE_URL=https://theofficecompany.hr

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder values with your actual Supabase credentials
# 3. You can find these values in:
#    - Supabase Dashboard → Settings → API
#    - OR copy from /Users/brunocukic/toc-crm/.env.local
# 4. Never commit .env.local to version control (already in .gitignore)

# Note: The anonymous key is for public read access
# The service role key is for the webhook to write blog posts
